# ============================================================
# QA-PILOT — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ── Django ──────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-django-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=qa_pilot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:12345@localhost:5432/qa_pilot

# ── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Gemini AI ────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyBHt9KT_-ZMZ3yAYcvOiykVREwjNngHofA
GEMINI_MODEL=gemma-3-4b-it

# ── FastAPI ──────────────────────────────────────────────────
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8001
FASTAPI_SECRET_KEY=your-fastapi-secret-key-here

# ── Scraper ──────────────────────────────────────────────────
SCRAPER_HEADLESS=True
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_DELAY_MIN=1
SCRAPER_DELAY_MAX=3

# ── Django JWT ───────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG
